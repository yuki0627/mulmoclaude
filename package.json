{
  "name": "mulmoclaude",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "author": "snakajima",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "concurrently -n server,client -k \"npm run server\" \"sleep 2 && vite\"",
    "dev:debug": "concurrently -n server,client -k \"npm run server:debug\" \"sleep 2 && vite\"",
    "dev:client": "vite",
    "dev:server": "tsx server/index.ts",
    "server": "tsx server/index.ts",
    "server:debug": "tsx server/index.ts --debug",
    "lint": "eslint src server",
    "format": "prettier --write '{src,server,test}/**/*.{ts,json,yaml,vue}'",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "build:client": "vite build",
    "build": "vite build && tsc -p server/tsconfig.json --noEmit",
    "test": "tsx --test ./test/*/test_*.ts ./test/*/*/test_*.ts",
    "sandbox:remove": "docker rmi mulmoclaude-sandbox",
    "sandbox:login": "security find-generic-password -s 'Claude Code-credentials' -w > ~/.claude/.credentials.json && echo 'Credentials exported to ~/.claude/.credentials.json'",
    "sandbox:logout": "rm -f ~/.claude/.credentials.json && echo 'Credentials file removed'"
  },
  "resolutions": {
    "tar": "7.5.13"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@gui-chat-plugin/browse": "^0.1.1",
    "@gui-chat-plugin/camera": "^0.3.0",
    "@gui-chat-plugin/canvas": "0.3.4",
    "@gui-chat-plugin/edit-image": "^0.3.0",
    "@gui-chat-plugin/markdown": "0.1.0",
    "@gui-chat-plugin/mindmap": "^0.3.1",
    "@gui-chat-plugin/music": "^1.0.0",
    "@gui-chat-plugin/othello": "^0.2.2",
    "@gui-chat-plugin/piano": "github:receptron/GUIChatPluginPiano",
    "@gui-chat-plugin/present3d": "^0.0.3",
    "@gui-chat-plugin/spreadsheet": "0.2.2",
    "@gui-chat-plugin/text-response": "0.1.2",
    "@gui-chat-plugin/weather": "^0.0.2",
    "@mulmocast/types": "^2.6.6",
    "@mulmochat-plugin/form": "0.3.2",
    "@mulmochat-plugin/generate-image": "0.3.3",
    "@mulmochat-plugin/quiz": "0.3.3",
    "@mulmochat-plugin/ui-image": "^0.3.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "gui-chat-protocol": "^0.0.4",
    "marked": "^18.0.0",
    "material-icons": "^1.13.14",
    "mulmocast": "^2.6.6",
    "puppeteer": "^24.40.0",
    "uuid": "^13.0.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vue-tsc": "^3.2.5"
  }
}
