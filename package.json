{
  "name": "mulmoclaude",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "author": "snakajima",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "predev": "yarn build:packages",
    "dev": "concurrently -n server,client -k \"npm run server\" \"sleep 2 && vite\"",
    "predev:debug": "yarn build:packages",
    "dev:debug": "concurrently -n server,client -k \"npm run server:debug\" \"sleep 2 && vite\"",
    "dev:client": "vite",
    "dev:server": "tsx server/index.ts",
    "server": "tsx server/index.ts",
    "server:debug": "tsx server/index.ts --debug",
    "cli": "tsx packages/cli/src/index.ts",
    "telegram": "tsx packages/telegram/src/index.ts",
    "lint": "eslint src server test e2e packages",
    "format": "prettier --write '{src,server,test,e2e,packages}/**/*.{ts,json,yaml,vue}'",
    "typecheck": "yarn typecheck:vue && yarn typecheck:server && yarn typecheck:test && yarn typecheck:e2e && yarn typecheck:packages",
    "typecheck:packages": "yarn workspaces run typecheck",
    "typecheck:vue": "vue-tsc --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "typecheck:test": "tsc -p test/tsconfig.json --noEmit",
    "typecheck:e2e": "tsc -p e2e/tsconfig.json --noEmit",
    "build:client": "vite build",
    "build:packages": "yarn workspace @mulmobridge/protocol run build && yarn workspace @receptron/task-scheduler run build && yarn workspace @mulmobridge/client run build && yarn workspace @mulmobridge/chat-service run build && yarn workspace @mulmobridge/cli run build && yarn workspace @mulmobridge/telegram run build && yarn workspace @mulmobridge/mock-server run build && yarn workspace @mulmobridge/discord run build && yarn workspace @mulmobridge/slack run build && yarn workspace @mulmobridge/line run build && yarn workspace @mulmobridge/whatsapp run build && yarn workspace @mulmobridge/matrix run build && yarn workspace @mulmobridge/irc run build",
    "build": "yarn build:packages && vite build",
    "test": "tsx --test ./test/*/test_*.ts ./test/*/*/test_*.ts ./test/*/*/*/test_*.ts && yarn workspaces run test",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:coverage": "tsx --test --experimental-test-coverage ./test/*/test_*.ts ./test/*/*/test_*.ts && yarn workspaces run test",
    "sandbox:remove": "docker rmi mulmoclaude-sandbox",
    "sandbox:login": "security find-generic-password -s 'Claude Code-credentials' -w > ~/.claude/.credentials.json && echo 'Credentials exported to ~/.claude/.credentials.json'",
    "sandbox:logout": "rm -f ~/.claude/.credentials.json && echo 'Credentials file removed'"
  },
  "resolutions": {
    "tar": "7.5.13"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@gui-chat-plugin/browse": "^0.2.0",
    "@gui-chat-plugin/camera": "^0.4.0",
    "@gui-chat-plugin/mindmap": "^0.4.0",
    "@gui-chat-plugin/present3d": "^0.1.0",
    "@gui-chat-plugin/weather": "^0.1.0",
    "@mulmobridge/client": "^0.1.0",
    "@mulmocast/types": "^2.6.7",
    "@mulmochat-plugin/form": "0.5.0",
    "@mulmochat-plugin/quiz": "0.4.0",
    "@mulmochat-plugin/ui-image": "^0.3.0",
    "@receptron/task-scheduler": "^0.1.0",
    "@types/dompurify": "^3.2.0",
    "cors": "^2.8.6",
    "dompurify": "^3.4.0",
    "dotenv": "^17.4.2",
    "echarts": "^6.0.0",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.1",
    "gui-chat-protocol": "0.1.0",
    "ignore": "^7.0.5",
    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "material-icons": "^1.13.14",
    "mulmocast": "^2.6.7",
    "node-pty": "^1.1.0",
    "puppeteer": "^24.41.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.32",
    "vue-drawing-canvas": "^1.0.14",
    "vue-router": "^5.0.3",
    "vuedraggable": "^4.1.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
